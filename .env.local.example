# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Jira (Phase 7)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your_jira_api_token
JIRA_USER_EMAIL=your_jira_email
JIRA_PROJECT_KEY=your_jira_project_key

# Confluence (Phase 8)
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_USER_EMAIL=your_confluence_email
CONFLUENCE_SPACE_KEY=your_space_key
CONFLUENCE_PARENT_PAGE_ID=optional_parent_page_id

# Gmail SMTP (Phase 8)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_no_spaces

# App URL for Morning Brew links
NEXT_PUBLIC_APP_URL=https://groww-support-pm-pulsator.vercel.app

# CRON Security (Phase 2)
CRON_SECRET=your_cron_secret_token
